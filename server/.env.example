# Backend Port (Render handles this automatically, but good for local dev)
PORT=5000

# MongoDB Connection String (Get from MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/prepvault?retryWrites=true&w=majority

# JWT Secret for signing cookies (Generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here

# JWT Expiration Time (e.g., 7d, 30d, 24h)
JWT_EXPIRES_IN=7d

# URL of the deployed frontend (e.g., https://your-prepvault-frontend.vercel.app)
# This is REQUIRED for CORS to allow the frontend to communicate with this backend
CLIENT_URL=http://localhost:5173

# Node Environment (Must be set to "production" on Render for Secure Cookies to work)
NODE_ENV=production
